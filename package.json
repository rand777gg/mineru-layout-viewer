{
  "name": "mineru-layout-viewer",
  "version": "0.1.1",
  "description": "Visualize MinerU layout.json output — side-by-side PDF + Markdown with bidirectional navigation",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/mineru-layout-viewer.iife.js"
    },
    "./web-component": {
      "types": "./dist/mineru-viewer.d.ts",
      "import": "./dist/mineru-viewer.mjs",
      "default": "./dist/mineru-layout-viewer.iife.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && node build.mjs",
    "dev": "node build.mjs --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mineru",
    "pdf",
    "markdown",
    "layout",
    "viewer",
    "web-component",
    "document-parsing"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "peerDependencies": {
    "pdfjs-dist": "^3.11.174",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
